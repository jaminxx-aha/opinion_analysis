# LLM配置
# provider: API格式 (openai/anthropic)
# runtime: 调用方式 (native/sdk, native=原生urllib零依赖适配内网, sdk=openai/anthropic SDK)
LLM_PROVIDER=openai
LLM_RUNTIME=native
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1

# 并发配置
LLM_MAX_CONCURRENT=5
LLM_MAX_TOKENS=8192
LLM_BATCH_SIZE=1

# 其他可选配置
# LLM_MAX_RETRIES=3
# LLM配置
# provider: API格式 (openai/anthropic)
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1

# 并发配置
LLM_MAX_CONCURRENT=1
LLM_MAX_TOKENS=1024
LLM_BATCH_SIZE=1

# 其他可选配置
# LLM_MAX_RETRIES=3
# LLM_TIMEOUT=30
# LLM_TEMPERATURE=0.7
# LLM_VERIFY_SSL=true
# LLM_LOG_LEVEL=DEBUG
# LLM_DISABLE_PROXY=false